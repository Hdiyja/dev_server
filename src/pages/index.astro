---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import AboutSpecs from '../components/AboutSpecs.astro';
import ProjectsMatrix from '../components/ProjectsMatrix.astro';
import ExperienceTimeline from '../components/ExperienceTimeline.astro';
import Contact from '../components/Contact.astro';

// Fetch collection items
import { getCollection } from 'astro:content';
const logbookEntries = await getCollection('logbook');
// Sort by date descending
logbookEntries.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Layout>
	<Hero />
	<AboutSpecs />
	<ProjectsMatrix />
	<ExperienceTimeline />

	<section class="border-y border-gray-800 p-8 md:p-12 surface-square relative shadow-[0_-20px_40px_rgba(0,0,0,0.5)]">
		<h2 class="text-3xl items-center font-bold tracking-tight text-white mb-2 relative z-10 font-sans">The Logbook</h2>
		<p class="font-mono text-gray-400 text-sm mb-8 max-w-xl relative z-10">
			Compiled thoughts, classical logs, and quantum explorations.
		</p>
		
		<div class="space-y-6 relative z-10">
			{logbookEntries.map((post) => (
				<a href={`/logbook/${post.id}`} class="block border border-l-2 border-l-brand-rust hover:border-l-brand-wave border-gray-800 p-6 transition-all group bg-black/60">
					<div class="flex items-center justify-between font-mono mb-4 text-xs">
						<span class="text-brand-wave group-hover:text-brand-amethyst transition-colors">>> {post.data.date.toISOString().slice(0, 10)}</span>
						<div class="flex gap-2 text-[10px] uppercase tracking-wider">
							{post.data.tags.map((tag) => (
								<span class="bg-gray-800 px-2.5 py-1 rounded text-gray-300 border border-gray-700">{tag}</span>
							))}
						</div>
					</div>
					<h3 class="text-xl font-bold text-gray-200 group-hover:text-white mb-3 font-sans transition-colors">{post.data.title}</h3>
					<p class="text-gray-400 font-sans text-sm line-clamp-3">{post.data.description}</p>
				</a>
			))}
		</div>
	</section>
	
	<Contact />
</Layout>
