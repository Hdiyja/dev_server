---
const githubLink = "https://github.com/Hdiyja";
const linkedinLink = "https://www.linkedin.com/in/gaudiosied/";
---

<section id="contact" class="py-24 relative z-10 bg-black overflow-hidden flex flex-col items-center justify-center border-t border-gray-900">
  <div class="pointer-events-none absolute inset-0 opacity-20">
    <div class="absolute inset-0 bg-[linear-gradient(to_right,#ce412b1a_1px,transparent_1px)] bg-[size:40px] shadow-[inset_0_0_100px_rgba(0,0,0,1)] mix-blend-screen h-full w-full mask-image:linear-gradient(to_bottom,black,transparent)"></div>
  </div>

  <div class="max-w-4xl w-full mx-auto px-6 text-center relative z-20">
    <div class="mb-4 inline-block font-mono text-xs uppercase tracking-widest text-brand-wave border border-brand-wave/30 px-3 py-1 bg-brand-wave/5">
      // System.Network.Connect()
    </div>
    
    <h2 class="text-5xl font-bold text-white mb-6 tracking-tight">Initiate Signal</h2>
    
    <p class="text-gray-400 font-sans max-w-2xl mx-auto mb-12 text-lg">
      Whether it's discussing optimized data structures, full-stack microservices, or a potential engineering role, my inbox is open.
    </p>

    <div class="flex flex-col sm:flex-row gap-6 justify-center items-center font-mono uppercase tracking-widest text-sm">
      <a 
        href={githubLink} 
        target="_blank" 
        rel="noopener noreferrer"
        class="flex items-center gap-3 px-8 py-4 border border-gray-700 bg-gray-900/50 hover:bg-[#0D1117] hover:border-white transition-all text-gray-300 hover:text-white shadow-lg backdrop-blur-sm"
      >
        <svg class="w-5 h-5 fill-current" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
        GitHub
      </a>

      <a 
        href={linkedinLink} 
        target="_blank" 
        rel="noopener noreferrer"
        class="flex items-center gap-3 px-8 py-4 border border-brand-wave/30 bg-[#0077b5]/10 hover:bg-[#0077b5]/20 hover:border-brand-wave transition-all text-brand-wave shadow-lg backdrop-blur-sm"
      >
        <svg class="w-5 h-5 fill-current" viewBox="0 0 24 24"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
        LinkedIn
      </a>
    </div>
  </div>
</section>